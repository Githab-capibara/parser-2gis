# =============================================================================
# Parser2GIS — Переменные окружения
# =============================================================================
#
# Скопируйте этот файл в .env и заполните значениями.
# cp .env.example .env
#
# ⚠️ ВАЖНО: Не храните токены и секреты в файлах проекта!
# Убедитесь что .env добавлен в .gitignore
#
# Linux:
#   export GITHUB_TOKEN="ghp_..."
#
# Этот файл НЕ должен содержать активных токенов.

# =============================================================================
# GITHUB (для работы с API)
# =============================================================================
# Получите токен в настройках GitHub:
# Settings → Developer settings → Personal access tokens → Fine-grained tokens
#
# Необходимые разрешения:
# - contents: read/write (для работы с файлами репозитория)
# - repository: full control (для полного доступа к репозиторию)
#
# GITHUB_TOKEN="ghp_..."

# =============================================================================
# ПАРАЛЛЕЛЬНЫЙ ПАРСИНГ
# =============================================================================
# Максимальное количество рабочих потоков (1-100, по умолчанию: 50)
# PARSER_MAX_WORKERS=50

# Минимальное количество рабочих потоков (по умолчанию: 1)
# PARSER_MIN_WORKERS=1

# Максимальный таймаут в секундах (60-172800, по умолчанию: 72000)
# PARSER_MAX_TIMEOUT=72000

# Таймаут по умолчанию в секундах (60-72000, по умолчанию: 7200)
# PARSER_DEFAULT_TIMEOUT=7200

# =============================================================================
# CONNECTION POOL (SQLite кэш)
# =============================================================================
# Максимальный размер пула соединений (5-50, по умолчанию: 20)
# PARSER_MAX_POOL_SIZE=20

# Минимальный размер пула соединений (1-10, по умолчанию: 5)
# PARSER_MIN_POOL_SIZE=5

# Максимальный возраст соединения в секундах (60-7200, по умолчанию: 600)
# PARSER_CONNECTION_MAX_AGE=600

# =============================================================================
# КЭШИРОВАНИЕ
# =============================================================================
# Максимальный размер кэша в MB (100-2000, по умолчанию: 500)
# PARSER_MAX_CACHE_SIZE_MB=500

# =============================================================================
# ВРЕМЕННЫЕ ФАЙЛЫ
# =============================================================================
# Максимальное количество временных файлов для мониторинга (100-10000, по умолчанию: 1000)
# PARSER_MAX_TEMP_FILES_MONITORING=1000

# Интервал очистки временных файлов в секундах (10-7200, по умолчанию: 120)
# PARSER_TEMP_FILE_CLEANUP_INTERVAL=120

# Возраст осиротевшего временного файла в секундах (60-172800, по умолчанию: 600)
# PARSER_ORPHANED_TEMP_FILE_AGE=600

# =============================================================================
# MERGE ОПЕРАЦИИ (слияние файлов)
# =============================================================================
# Таймаут блокировки слияния в секундах (60-14400, по умолчанию: 7200)
# PARSER_MERGE_LOCK_TIMEOUT=7200

# Максимальный возраст lock-файла в секундах (10-1200, по умолчанию: 120)
# PARSER_MAX_LOCK_FILE_AGE=120

# =============================================================================
# CHROME (браузер)
# =============================================================================
# Лимит памяти браузера в MB (по умолчанию: 2048)
# PARSER_MEMORY_LIMIT_MB=2048

# Начальный порт для remote debugging (по умолчанию: 9222)
# PARSER_DEBUG_PORT_START=9222

# Конечный порт для remote debugging (по умолчанию: 9322)
# PARSER_DEBUG_PORT_END=9322

# Максимальное количество попыток запуска Chrome (по умолчанию: 3)
# PARSER_CHROME_MAX_STARTUP_ATTEMPTS=3

# Таймаут навигации в секундах (по умолчанию: 300)
# PARSER_NAVIGATION_TIMEOUT=300

# Доля памяти для cleanup (0.0-1.0, по умолчанию: 0.75)
# PARSER_MEMORY_CLEANUP_FRACTION=0.75

# =============================================================================
# CSV WRITER
# =============================================================================
# Размер буфера CSV writer (по умолчанию: 524288 = 512KB)
# PARSER_CSV_BUFFER_SIZE=524288

# =============================================================================
# XDG DIRECTORIES (Linux)
# =============================================================================
# Директория конфигурации (по умолчанию: ~/.config)
# XDG_CONFIG_HOME=~/.config

# Директория данных (по умолчанию: ~/.local/share)
# XDG_DATA_HOME=~/.local/share

# Директория кэша (по умолчанию: ~/.cache)
# XDG_CACHE_HOME=~/.cache

# =============================================================================
# ЛОГИРОВАНИЕ
# =============================================================================
# Уровень логирования (DEBUG, INFO, WARNING, ERROR)
# PARSER_LOG_LEVEL=INFO
